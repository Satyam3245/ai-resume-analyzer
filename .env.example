# AI & Search API Keys
GEMINI_API_KEY="your_gemini_api_key_here"              # Get from Google AI Studio
TAVILY_API_KEY="tvly-your_tavily_api_key_here"        # Get from Tavily Dashboard

# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Authentication (NextAuth)
AUTH_SECRET="run_openssl_rand_base64_32_to_generate_this" # Generate with: openssl rand -base64 32

# GitHub OAuth Provider
GITHUB_CLIENT_ID="lv1.your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret_here"

# Google OAuth Provider
GOOGLE_CLIENT_ID="your_google_client_://googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_google_client_secret_here"
